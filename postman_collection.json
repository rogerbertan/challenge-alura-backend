              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"nome\": \"Sala de Reuniões A\",\n    \"capacidade\": 10\n  },\n  {\n    \"id\": 2,\n    \"nome\": \"Sala de Conferências\",\n    \"capacidade\": 50\n  }\n]"
