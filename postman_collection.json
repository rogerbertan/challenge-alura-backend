    {
      "name": "Reservas",
      "description": "Endpoints for managing reservations (reservas)",
      "item": [
        {
          "name": "Get All Reservas (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reservas?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reservas"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page number (0-indexed)"
                },
                {
                  "key": "size",
                  "value": "10",
                  "description": "Number of items per page"
                }
              ]
            },
            "description": "Retrieves a paginated list of all reservations"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"content\": [\n    {\n      \"id\": 1,\n      \"usuario\": {\n        \"id\": 1,\n        \"nome\": \"João Silva\",\n        \"email\": \"joao.silva@email.com\"\n      },\n      \"sala\": {\n        \"id\": 1,\n        \"nome\": \"Sala de Reuniões A\",\n        \"capacidade\": 10\n      },\n      \"dataHoraInicio\": \"2024-01-15T09:00:00\",\n      \"dataHoraFim\": \"2024-01-15T10:00:00\",\n      \"statusReserva\": \"ATIVA\"\n    }\n  ],\n  \"pageable\": {\n    \"pageNumber\": 0,\n    \"pageSize\": 10\n  },\n  \"totalElements\": 1,\n  \"totalPages\": 1\n}"
            }
          ]
        },
        {
          "name": "Get Reserva by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reservas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reservas", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Reserva ID"
                }
              ]
            },
            "description": "Retrieves a specific reservation by its ID"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"usuario\": {\n    \"id\": 1,\n    \"nome\": \"João Silva\",\n    \"email\": \"joao.silva@email.com\"\n  },\n  \"sala\": {\n    \"id\": 1,\n    \"nome\": \"Sala de Reuniões A\",\n    \"capacidade\": 10\n  },\n  \"dataHoraInicio\": \"2024-01-15T09:00:00\",\n  \"dataHoraFim\": \"2024-01-15T10:00:00\",\n  \"statusReserva\": \"ATIVA\"\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "\"Reserva não encontrada\""
            }
          ]
        },
        {
          "name": "Create Reserva",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": 1,\n  \"salaId\": 1,\n  \"dataHoraInicio\": \"2024-01-15T09:00:00\",\n  \"dataHoraFim\": \"2024-01-15T10:00:00\",\n  \"numeroPessoas\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reservas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reservas"]
            },
            "description": "Creates a new reservation. Validates that the room is available during the requested time period and that the end time is after the start time."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "\"Reserva cadastrada com sucesso!\""
            },
            {
              "name": "Room Not Available",
              "status": "Bad Request",
              "code": 400,
              "body": "\"Sala não disponível no horário solicitado\""
            },
            {
              "name": "Invalid Time",
              "status": "Bad Request",
              "code": 400,
              "body": "\"Data e hora de fim deve ser maior que data e hora de início\""
            }
          ]
        },
